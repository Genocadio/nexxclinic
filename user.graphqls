scalar JSON

enum ResponseStatus {
  SUCCESS
  ERROR
  UNAUTHENTICATED
  UNAUTHORISED
  PARTIAL_SUCCESS
}

enum RoleName {
  MANAGER
  CLINIC_ADMIN
  FINANCE
  STAFF
  RECEPTION
  NURSE
  CLINICIAN
  ADMIN
}

enum AccountStatus {
  PENDING
  ACTIVE
  DISABLED
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum DocumentType {
  LICENSE
  DIPLOMA_CERTIFICATE
  DEGREE_CERTIFICATE
  TRAINING_CERTIFICATE
  NATIONAL_ID
  PASSPORT
  BACKGROUND_CHECK
  WORK_PERMIT
  OTHER
}

enum ProductType {
  DRUG
  MEDICAL_ACT
  BIOLOGICAL_ACT
  CONSUMABLE_DEVICE
}

enum ProductUnit {
  TABLET
  CAPSULE
  PESSARY
  SUPPOSITORY
  BOX_OF_6_TABLETS
  BOX_OF_7_PESSARIES
  BOX_OF_9_TABLETS
  BOX_OF_12_TABLETS
  BOX_OF_12_PESSARIES
  BOX_OF_14_TABLETS
  BOX_OF_18_TABLETS
  BOX_OF_18_PESSARIES
  BOX_OF_24_TABLETS
  BOX_OF_1_PESSARY
  BOX_OF_3_PESSARIES
  BOX_OF_6_PESSARIES
  BOTTLE
  VIAL
  AMPOULE
  TUBE
  TUBE_OF_15_TABLETS
  TUBE_OF_20_TABLETS
  TUBE_OF_50_STRIPS
  BOX
  SACHET
  POT
  ROLL
  PIECE
  DOSE
  KIT_OF_ONE_DAY_DOSE
  PCS
  UNKNOWN
}

enum MustPrescribedBy {
  ALL
}

enum DrugAdministrationFrequency {
  CUSTOM_HOURS
}

enum DepartmentInsurancePolicyMode {
  ALL
  ONLY
  EXCEPT
}

enum VisitStatus {
  CREATED
  IN_PROGRESS
  CANCELLED
  COMPLETED
}A

enum VisitProductStatus {
  BILLED
  EXEMPTED
  UNPAID
  PENDING
}

enum VisitDepartmentStatus {
  ACTIVE
  PENDING
  COMPLETED
}

enum VisitBillingStatus {
  UNPAID
  PARTIALLY_PAID
  PAID
}

enum FormStatus {
  DRAFT
  FINAL
}

enum FieldType {
  text
  email
  number
  date
  textarea
  actionListener
  select
  radio
  checkbox
  table
  signature
  file
  heading
  paragraph
}

enum TableMode {
  STATIC
  DYNAMIC
}

enum ConditionalCondition {
  equals
  not_equals
  contains
  not_contains
  greater_than
  less_than
  is_empty
  is_not_empty
}

enum AnswerStatus {
  DRAFT
  FINAL
}

interface ApiResponse {
  status: ResponseStatus!
  message: String
}

type PaginationInfo {
  total: Int!
  perPage: Int!
  currentPage: Int!
  totalPages: Int!
}

type AuthTokens {
  accessToken: String
  refreshToken: String
  user: Worker
}

type AuthResponse implements ApiResponse {
  status: ResponseStatus!
  message: String
  data: AuthTokens
}

type BooleanResponse implements ApiResponse {
  status: ResponseStatus!
  message: String
  data: Boolean
}

type StringResponse implements ApiResponse {
  status: ResponseStatus!
  message: String
  data: String
}

type Worker {
  id: ID!
  firstName: String!
  lastName: String
  email: String
  phoneNumber: String
  username: String
  accountStatus: AccountStatus!
  roles: [RoleName!]!
  department: Department
  createdAt: String!
  updatedAt: String!
}

type WorkerResponse implements ApiResponse {
  status: ResponseStatus!
  message: String
  data: Worker
}

type WorkerListResponse implements ApiResponse {
  status: ResponseStatus!
  message: String
  data: [Worker!]
}

type AuditLog {
  id: ID!
  action: String!
  details: String
  timestamp: String!
}

type AuditLogListResponse implements ApiResponse {
  status: ResponseStatus!
  message: String
  data: [AuditLog!]
}

type InsuranceProvider {
  id: ID!
  insuranceName: String!
  acronym: String
  defaultCoveragePercentage: Int!
  supportedByClinic: Boolean!
  iconUrl: String
  createdAt: String!
  updatedAt: String!
}

type InsuranceProviderResponse implements ApiResponse {
  status: ResponseStatus!
  message: String
  data: InsuranceProvider
}

type PaginatedInsuranceProviderResponse implements ApiResponse {
  status: ResponseStatus!
  message: String
  data: [InsuranceProvider!]
  pagination: PaginationInfo
}

type Patient {
  id: ID!
  firstName: String!
  middleName: String
  lastName: String
  dateOfBirth: String!
  gender: Gender!
  primaryPhoneNumber: String
  alternativePhone: String
  village: String
  city: String
  district: String
  postalAddress: String
  nationalIdNumber: String
  passportNumber: String
  emergencyContactName: String
  emergencyContactRelationship: String
  emergencyContactPhoneNumber: String
  lastVisit: Visit
  createdAt: String!
  updatedAt: String!
}

type PatientResponse implements ApiResponse {
  status: ResponseStatus!
  message: String
  data: Patient
}

type PaginatedPatientResponse implements ApiResponse {
  status: ResponseStatus!
  message: String
  data: [Patient!]
  pagination: PaginationInfo
}

type PatientInsurance {
  id: ID!
  patient: Patient!
  insuranceProvider: InsuranceProvider!
  insuranceCardNumber: String!
  providingCompanyOrEmployer: String
  principalMember: Boolean!
  principalMemberName: String
  principalMemberPhoneNumber: String
  validFrom: String!
  validUntil: String!
  createdAt: String!
  updatedAt: String!
}

type PatientInsuranceResponse implements ApiResponse {
  status: ResponseStatus!
  message: String
  data: PatientInsurance
}

type PaginatedPatientInsuranceResponse implements ApiResponse {
  status: ResponseStatus!
  message: String
  data: [PatientInsurance!]
  pagination: PaginationInfo
}

type ProductInsuranceCoverage {
  id: ID!
  insuranceProvider: InsuranceProvider!
  cost: Float!
  covered: Boolean!
  requireMedicalAdvisor: Boolean!
  mustPrescribedBy: MustPrescribedBy!
  drugAdministrationFrequency: DrugAdministrationFrequency!
  authorizationRequestReasons: [String!]!
  createdAt: String!
  updatedAt: String!
}

type Product {
  id: ID!
  name: String!
  genericName: String
  code: String!
  description: String!
  type: ProductType!
  unit: ProductUnit!
  metadata: JSON
  privateRhicPrice: Float
  clinicPrice: Float
  insuranceCoverages: [ProductInsuranceCoverage!]!
  createdAt: String!
  updatedAt: String!
}

type ProductResponse implements ApiResponse {
  status: ResponseStatus!
  message: String
  data: Product
}

type PaginatedProductResponse implements ApiResponse {
  status: ResponseStatus!
  message: String
  data: [Product!]
  pagination: PaginationInfo
}

type ProductInsuranceCoverageResponse implements ApiResponse {
  status: ResponseStatus!
  message: String
  data: ProductInsuranceCoverage
}

type Department {
  id: ID!
  name: String!
  insurancePolicyMode: DepartmentInsurancePolicyMode!
  insurancePolicies: [InsuranceProvider!]!
  defaultProducts: [Product!]!
  createdAt: String!
  updatedAt: String!
}

type DepartmentResponse implements ApiResponse {
  status: ResponseStatus!
  message: String
  data: Department
}

type PaginatedDepartmentResponse implements ApiResponse {
  status: ResponseStatus!
  message: String
  data: [Department!]
  pagination: PaginationInfo
}

type Visit {
  id: ID!
  patient: Patient!
  status: VisitStatus!
  visitDate: String!
  linkedInsurances: [PatientInsurance!]!
  departments: [VisitDepartment!]!
}

type VisitDepartment {
  id: ID!
  department: Department!
  status: VisitDepartmentStatus!
  completedAt: String
  products: [VisitDepartmentProduct!]!
  createdAt: String!
  updatedAt: String!
}

type VisitDepartmentProduct {
  id: ID!
  product: Product!
  quantity: Float!
  price: Float!
  status: VisitProductStatus!
  addedBy: Worker
  billedBy: Worker
  createdAt: String!
  updatedAt: String!
}

type VisitResponse implements ApiResponse {
  status: ResponseStatus!
  message: String
  data: Visit
}

type VisitBillingItem {
  id: ID!
  visitDepartmentProductId: ID!
  productId: ID!
  productName: String!
  unitPriceSnapshot: Float!
  quantitySnapshot: Float!
  lineTotal: Float!
  insuranceCoveredAmount: Float!
  patientPayableAmount: Float!
  appliedPatientInsuranceId: ID
  createdAt: String!
  updatedAt: String!
}

type VisitBilling {
  id: ID!
  visitId: ID!
  status: VisitBillingStatus!
  billingDate: String!
  totalAmount: Float!
  insuranceCoveredAmount: Float!
  patientPayableAmount: Float!
  paidAmount: Float!
  outstandingAmount: Float!
  fullyBilledVisit: Boolean!
  billedBy: Worker
  items: [VisitBillingItem!]!
}

type VisitBillingResponse implements ApiResponse {
  status: ResponseStatus!
  message: String
  data: VisitBilling
}

type VisitBillingListResponse implements ApiResponse {
  status: ResponseStatus!
  message: String
  data: [VisitBilling!]
}

type PaginatedVisitResponse implements ApiResponse {
  status: ResponseStatus!
  message: String
  data: [Visit!]
  pagination: PaginationInfo
}

type ConditionalRendering {
  dependsOn: String!
  condition: ConditionalCondition!
  value: String
  itemType: String
}

type TableConfig {
  mode: TableMode!
  rows: Int
  columns: Int
  headerPlacement: String
  columnHeaders: [String!]
  rowHeaders: [String!]
}

type FormField {
  id: String!
  label: String!
  type: FieldType!
  placeholder: String
  required: Boolean!
  order: Int!
  hideLabel: Boolean!
  boldLabel: Boolean!
  italicLabel: Boolean!
  underlineLabel: Boolean!
  centerLabel: Boolean!
  options: [String!]
  tableConfig: TableConfig
  conditionalRendering: ConditionalRendering
}

type FormSection {
  id: String!
  title: String!
  boldTitle: Boolean!
  italicTitle: Boolean!
  underlineTitle: Boolean!
  centerTitle: Boolean!
  columns: Int!
  order: Int!
  fields: [FormField!]
}

type FormAction {
  id: String!
  name: String!
  type: String!
  quantity: Int!
  price: Float!
  isQuantifiable: Boolean!
  backendId: String
}

type Form {
  id: ID!
  departmentId: ID!
  title: String!
  description: String
  status: FormStatus!
  version: String!
  createdAt: String!
  updatedAt: String!
  sections: [FormSection!]
  fields: [FormField!]
  actions: [FormAction!]
}

type FormVersion {
  id: ID!
  formId: ID!
  departmentId: ID!
  title: String!
  description: String
  status: FormStatus!
  version: String!
  createdAt: String!
  updatedAt: String!
  sections: [FormSection!]
  fields: [FormField!]
  actions: [FormAction!]
}

type FormResponse implements ApiResponse {
  status: ResponseStatus!
  message: String
  data: Form
}

type FormListResponse implements ApiResponse {
  status: ResponseStatus!
  message: String
  data: [Form!]
}

type FormVersionResponse implements ApiResponse {
  status: ResponseStatus!
  message: String
  data: FormVersion
}

type FormVersionListResponse implements ApiResponse {
  status: ResponseStatus!
  message: String
  data: [FormVersion!]
}

type ConsultationAnswers {
  id: ID!
  consultationId: ID!
  visitId: ID!
  patientId: ID!
  departmentId: ID!
  formId: ID!
  formVersion: String!
  status: AnswerStatus!
  answers: String!
  submittedAt: String
  updatedAt: String!
}

type ConsultationAnswersResponse implements ApiResponse {
  status: ResponseStatus!
  message: String
  data: ConsultationAnswers
}

input WorkerDocumentInput {
  type: DocumentType
  title: String
  isRequired: Boolean
  documentUrl: String
  documentNumber: String
  hasExpiration: Boolean
  expirationDate: String
  issuedBy: String
  issuedDate: String
  notes: String
}

