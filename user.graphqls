  name: String
  phoneNumber: String
  insuranceProviderId: ID
  age: Int
  minAge: Int
  maxAge: Int
  page: Int
  size: Int
}

input SearchInsuranceProvidersInput {
  query: String
  supportedByClinic: Boolean
  page: Int
  size: Int
}

input CreateProductInsuranceCoverageInput {
  insuranceProviderId: ID!
  cost: Float
  covered: Boolean
  requireMedicalAdvisor: Boolean
  mustPrescribedBy: MustPrescribedBy
  drugAdministrationFrequency: DrugAdministrationFrequency
  authorizationRequestReasons: [String!]
}

input UpdateProductInsuranceCoverageInput {
  insuranceProviderId: ID!
  cost: Float
  covered: Boolean
  requireMedicalAdvisor: Boolean
  mustPrescribedBy: MustPrescribedBy
  drugAdministrationFrequency: DrugAdministrationFrequency
  authorizationRequestReasons: [String!]
}

input CreateProductInput {
  id: ID
  name: String!
  genericName: String
  code: String!
  description: String!
  type: ProductType!
  unit: ProductUnit!
  metadata: JSON
  privateRhicPrice: Float
  clinicPrice: Float
  insuranceCoverages: [CreateProductInsuranceCoverageInput!]
}

input UpdateProductInput {
  name: String
  genericName: String
  code: String
  description: String
  type: ProductType
  unit: ProductUnit
  metadata: JSON
  privateRhicPrice: Float
  clinicPrice: Float
