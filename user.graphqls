}

input CreateDepartmentInput {
  name: String!
  insurancePolicyMode: DepartmentInsurancePolicyMode
  insuranceProviderIds: [ID!]
  defaultProductIds: [ID!]
}

input UpdateDepartmentInput {
  name: String
  insurancePolicyMode: DepartmentInsurancePolicyMode
  insuranceProviderIds: [ID!]
  defaultProductIds: [ID!]
}

