}

input ConsultationAnswersInput {
  consultationId: ID!
  visitId: ID!
  patientId: ID!
  departmentId: ID!
  formId: ID!
  formVersion: String
  status: AnswerStatus!
  answers: String!
}

type Query {
  me: WorkerResponse!
  listUsers: WorkerListResponse!
  adminAuditLogs: AuditLogListResponse!
  insuranceProvider(insuranceProviderId: ID!): InsuranceProviderResponse!
  insuranceProviders(input: SearchInsuranceProvidersInput): PaginatedInsuranceProviderResponse!
  patient(patientId: ID!): PatientResponse!
  patients: PaginatedPatientResponse!
  patientInsurances(patientId: ID!): PaginatedPatientInsuranceResponse!
  searchPatients(input: SearchPatientsInput): PaginatedPatientResponse!
  product(productId: ID!): ProductResponse!
  products(input: SearchProductsInput): PaginatedProductResponse!
  productInsuranceCoverage(productInsuranceCoverageId: ID!): ProductInsuranceCoverageResponse!
  department(departmentId: ID!): DepartmentResponse!
  departments(input: SearchDepartmentsInput): PaginatedDepartmentResponse!
  visit(visitId: ID!): VisitResponse!
  visits(input: SearchVisitsInput): PaginatedVisitResponse!
  visitBilling(visitBillingId: ID!): VisitBillingResponse!
  visitBillings(visitId: ID!): VisitBillingListResponse!
  getForms(departmentId: ID!): FormListResponse!
  getForm(departmentId: ID!, formId: ID!): FormResponse!
  getLatestForm(departmentId: ID!): FormResponse!
  getFormVersionHistory(departmentId: ID!, formId: ID!): FormVersionListResponse!
  getFormVersion(departmentId: ID!, formId: ID!, version: String!): FormVersionResponse!
  getConsultationAnswers(consultationId: ID!, departmentId: ID!, formId: ID!): ConsultationAnswersResponse!
}

type Mutation {
  selfRegister(input: SelfRegisterInput!): WorkerResponse!
  adminCreateUser(input: AdminCreateUserInput!): WorkerResponse!
  activateUser(input: ActivateUserInput!): WorkerResponse!
  deactivateUser(input: DeactivateUserInput!): WorkerResponse!
  login(input: LoginInput!): AuthResponse!
  setInitialPassword(input: SetInitialPasswordInput!): BooleanResponse!
  refreshSession(input: RefreshSessionInput!): AuthResponse!
  refreshToken(input: RefreshTokenInput!): AuthResponse!
  logout(input: LogoutInput): BooleanResponse!
  updateMyProfile(input: UpdateMyProfileInput!): WorkerResponse!
  changeMyPassword(input: ChangeMyPasswordInput!): BooleanResponse!
  adminTriggerPasswordReset(input: AdminTriggerPasswordResetInput!): BooleanResponse!
  adminSetUserSessionLimit(input: AdminSetUserSessionLimitInput!): BooleanResponse!
  createInsuranceProvider(input: CreateInsuranceProviderInput!): InsuranceProviderResponse!
  updateInsuranceProvider(insuranceProviderId: ID!, input: UpdateInsuranceProviderInput!): InsuranceProviderResponse!
  deleteInsuranceProvider(insuranceProviderId: ID!): BooleanResponse!
  createPatient(input: CreatePatientInput!): PatientResponse!
  updatePatient(patientId: ID!, input: UpdatePatientInput!): PatientResponse!
  deletePatient(patientId: ID!): BooleanResponse!
  createPatientInsurance(input: CreatePatientInsuranceInput!): PatientInsuranceResponse!
  updatePatientInsurance(patientInsuranceId: ID!, input: UpdatePatientInsuranceInput!): PatientInsuranceResponse!
  deletePatientInsurance(patientInsuranceId: ID!): BooleanResponse!
  createProduct(input: CreateProductInput!): ProductResponse!
  updateProduct(productId: ID!, input: UpdateProductInput!): ProductResponse!
  createProductInsuranceCoverage(productId: ID!, input: CreateProductInsuranceCoverageInput!): ProductInsuranceCoverageResponse!
  updateProductInsuranceCoverage(productInsuranceCoverageId: ID!, input: UpdateProductInsuranceCoverageInput!): ProductInsuranceCoverageResponse!
  deleteProductInsuranceCoverage(productInsuranceCoverageId: ID!): BooleanResponse!
  createDepartment(input: CreateDepartmentInput!): DepartmentResponse!
  updateDepartment(departmentId: ID!, input: UpdateDepartmentInput!): DepartmentResponse!
  createVisit(input: CreateVisitInput!): VisitResponse!
  changeVisitDate(input: ChangeVisitDateInput!): VisitResponse!
  addVisitDepartment(visitId: ID!, departmentId: ID!): VisitResponse!
  completeVisitDepartment(visitDepartmentId: ID!): VisitResponse!
  addVisitDepartmentProduct(input: CreateVisitDepartmentProductInput!): VisitResponse!
  updateVisitDepartmentProductStatus(input: UpdateVisitDepartmentProductStatusInput!): VisitResponse!
  updateVisitDepartmentStatus(input: UpdateVisitDepartmentStatusInput!): VisitResponse!
  updateVisitDepartmentProductQuantity(input: UpdateVisitDepartmentProductQuantityInput!): VisitResponse!
  billVisit(input: BillVisitInput!): VisitBillingResponse!
  recordVisitBillingPayment(input: RecordVisitBillingPaymentInput!): VisitBillingResponse!
  completeVisit(visitId: ID!): VisitResponse!
  cancelVisit(visitId: ID!): VisitResponse!
  createForm(departmentId: ID!, input: FormInput!): FormResponse!
  updateForm(departmentId: ID!, formId: ID!, input: FormInput!): FormResponse!
  finalizeForm(departmentId: ID!, formId: ID!): FormResponse!
  upsertConsultationAnswers(input: ConsultationAnswersInput!): ConsultationAnswersResponse!
}
