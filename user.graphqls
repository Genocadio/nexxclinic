  patientId: ID
  insuranceProviderId: ID
  insuranceCardNumber: String
  providingCompanyOrEmployer: String
  principalMember: Boolean
  principalMemberName: String
  principalMemberPhoneNumber: String
  validFrom: String
  validUntil: String
}

